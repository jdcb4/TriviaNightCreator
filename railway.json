{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "trivia-monolith": {
      "name": "trivia-night-creator",
      "watchPaths": [
        "apps/api/**",
        "apps/web/**",
        "packages/**",
        "Dockerfile"
      ],
      "build": {
        "builder": "DOCKER",
        "dockerfilePath": "Dockerfile"
      },
      "deploy": {
        "healthcheckPath": "/api/health",
        "healthcheckTimeout": 120,
        "restartPolicyType": "ON_FAILURE"
      }
    }
  }
}
