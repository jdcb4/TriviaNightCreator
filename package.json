{
  "name": "trivia-night-creator-root",
  "version": "1.3.0",
  "private": true,
  "description": "No-account trivia night builder and host tool for in-person events",
  "scripts": {
    "dev:db": "docker-compose up -d",
    "dev": "pnpm --parallel --filter \"@trivia/*\" run dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "verify": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run build"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "prettier": "^3.2.5"
  },
  "packageManager": "pnpm@9.15.0+sha512.76e2379760a4328ec4415815bcd6628dee727af3779aaa4c914e3944156c4299921a89f976381ee107d41f12cfa4b66681ca9c718f0668fa0831ed4c6d8ba56c"
}
