{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "baseUrl": ".",
    "paths": {
      "@trivia/shared": ["./packages/shared/src/index.ts"],
      "@trivia/domain": ["./packages/domain/src/index.ts"],
      "@trivia/db": ["./packages/db/src/index.ts"],
      "@trivia/pdf": ["./packages/pdf/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
